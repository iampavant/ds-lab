  </div>
  <div id="arr-tab">
    <div id="arr-theory" class="tab-content active">
      <div class="highlight-box">
        <h4>Array ADT Operations</h4>
        <ul>
          <li><strong>Access:</strong> A[i] — O(1) direct access via base address + offset</li>
          <li><strong>Insert:</strong> Shift elements right, then place — O(n) worst case</li>
          <li><strong>Delete:</strong> Shift elements left after removal — O(n) worst case</li>
          <li><strong>Search:</strong> Linear O(n) or Binary O(log n) if sorted</li>
          <li><strong>Traverse:</strong> Visit each element — O(n)</li>
        </ul>
      </div>
      <div class="info-box warning">
        <h4>⚠️ Limitations</h4>
        <p>Fixed size once declared, insertion/deletion O(n), wasted memory if underutilized.</p>
      </div>
    </div>
    <div id="arr-pseudo" class="tab-content">
      <div class="code-block">
        <div class="code-header">
          <div style="display:flex;align-items:center;gap:8px;"><div class="code-dots"><div class="code-dot dot-r"></div><div class="code-dot dot-y"></div><div class="code-dot dot-g"></div></div><span>Array ADT — Pseudocode</span></div>
          <button class="copy-btn" onclick="copyCode(this)">copy</button>
        </div>
        <pre><span class="cm">// Array ADT Abstract Definition</span>
<span class="tp">Array</span> A[MAX_SIZE]
<span class="tp">int</span> n = current size

<span class="cm">// ACCESS: Return element at index i</span>
<span class="kw">FUNCTION</span> <span class="fn">Access</span>(A, i):
  <span class="kw">IF</span> i < 0 OR i >= n: <span class="kw">return</span> ERROR
  <span class="kw">return</span> A[i]

<span class="cm">// INSERT: Add x at position pos</span>
<span class="kw">FUNCTION</span> <span class="fn">Insert</span>(A, pos, x):
  <span class="kw">IF</span> n == MAX_SIZE: <span class="kw">return</span> OVERFLOW
  <span class="kw">FOR</span> i = n-1 <span class="kw">DOWNTO</span> pos:
    A[i+1] = A[i]     <span class="cm">// shift right</span>
  A[pos] = x
  n = n + 1

<span class="cm">// DELETE: Remove element at pos</span>
<span class="kw">FUNCTION</span> <span class="fn">Delete</span>(A, pos):
  <span class="kw">IF</span> n == 0: <span class="kw">return</span> UNDERFLOW
  <span class="kw">FOR</span> i = pos <span class="kw">TO</span> n-2:
    A[i] = A[i+1]     <span class="cm">// shift left</span>
  n = n - 1</pre>
      </div>
    </div>
    <div id="arr-cpp" class="tab-content">
      <div class="code-block">
        <div class="code-header">
          <div style="display:flex;align-items:center;gap:8px;"><div class="code-dots"><div class="code-dot dot-r"></div><div class="code-dot dot-y"></div><div class="code-dot dot-g"></div></div><span>array_adt.cpp</span></div>
          <button class="copy-btn" onclick="copyCode(this)">copy</button>
        </div>
        <pre><span class="kw">#include</span> <span class="str">&lt;iostream&gt;</span>
<span class="kw">using namespace</span> std;

<span class="kw">class</span> <span class="tp">ArrayADT</span> {
    <span class="kw">int</span>* arr;
    <span class="kw">int</span> maxSize, n;
<span class="kw">public</span>:
    <span class="fn">ArrayADT</span>(<span class="kw">int</span> size) {
        maxSize = size;
        arr = <span class="kw">new int</span>[size];
        n = <span class="num">0</span>;
    }

    <span class="cm">// O(1) — direct access</span>
    <span class="kw">int</span> <span class="fn">access</span>(<span class="kw">int</span> i) {
        <span class="kw">if</span>(i < <span class="num">0</span> || i >= n) <span class="kw">throw</span> <span class="fn">runtime_error</span>(<span class="str">"Index out of bounds"</span>);
        <span class="kw">return</span> arr[i];
    }

    <span class="cm">// O(n) — shift elements right</span>
    <span class="kw">void</span> <span class="fn">insert</span>(<span class="kw">int</span> pos, <span class="kw">int</span> x) {
        <span class="kw">if</span>(n == maxSize) { cout << <span class="str">"Overflow!\n"</span>; <span class="kw">return</span>; }
        <span class="kw">for</span>(<span class="kw">int</span> i = n-<span class="num">1</span>; i >= pos; i--)
            arr[i+<span class="num">1</span>] = arr[i];
        arr[pos] = x;
        n++;
    }

    <span class="cm">// O(n) — shift elements left</span>
    <span class="kw">void</span> <span class="fn">remove</span>(<span class="kw">int</span> pos) {
        <span class="kw">if</span>(n == <span class="num">0</span>) { cout << <span class="str">"Underflow!\n"</span>; <span class="kw">return</span>; }
        <span class="kw">for</span>(<span class="kw">int</span> i = pos; i < n-<span class="num">1</span>; i++)
            arr[i] = arr[i+<span class="num">1</span>];
        n--;
    }

    <span class="kw">void</span> <span class="fn">display</span>() {
        <span class="kw">for</span>(<span class="kw">int</span> i = <span class="num">0</span>; i < n; i++)
            cout << arr[i] << <span class="str">" "</span>;
        cout << endl;
    }

    ~<span class="fn">ArrayADT</span>() { <span class="kw">delete</span>[] arr; }
};

<span class="kw">int</span> <span class="fn">main</span>() {
    <span class="tp">ArrayADT</span> a(<span class="num">10</span>);
    a.<span class="fn">insert</span>(<span class="num">0</span>, <span class="num">10</span>); a.<span class="fn">insert</span>(<span class="num">1</span>, <span class="num">20</span>); a.<span class="fn">insert</span>(<span class="num">2</span>, <span class="num">30</span>);
    a.<span class="fn">display</span>();    <span class="cm">// 10 20 30</span>
    a.<span class="fn">remove</span>(<span class="num">1</span>);
    a.<span class="fn">display</span>();    <span class="cm">// 10 30</span>
    cout << a.<span class="fn">access</span>(<span class="num">0</span>) << endl; <span class="cm">// 10</span>
}</pre>
      </div>
    </div>
  </div>
</section>

<!-- ======================== POLYNOMIAL ======================== -->
<section id="polynomial" class="section">
  <div class="section-badge badge-purple">Unit I</div>
  <h2>Single Variable Polynomial</h2>
  <p>Representing and manipulating polynomials like 3x³ + 2x² - 5x + 1 using arrays.</p>
  <div class="info-box">
    <h4>📐 Representation</h4>
    <p>A polynomial of degree n is stored as array where index = exponent, value = coefficient. p[i] = coefficient of xⁱ</p>
  </div>
  <div class="code-block">
    <div class="code-header"><div style="display:flex;align-items:center;gap:8px;"><div class="code-dots"><div class="code-dot dot-r"></div><div class="code-dot dot-y"></div><div class="code-dot dot-g"></div></div><span>polynomial.cpp</span></div><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
    <pre><span class="kw">#include</span> <span class="str">&lt;iostream&gt;</span>
<span class="kw">using namespace</span> std;

<span class="kw">const int</span> MAX = <span class="num">10</span>;

<span class="cm">// Evaluate polynomial using Horner's method: O(n)</span>
<span class="kw">double</span> <span class="fn">evaluate</span>(<span class="kw">int</span> p[], <span class="kw">int</span> deg, <span class="kw">double</span> x) {
    <span class="kw">double</span> result = p[deg];
    <span class="kw">for</span>(<span class="kw">int</span> i = deg-<span class="num">1</span>; i >= <span class="num">0</span>; i--)
        result = result * x + p[i];
    <span class="kw">return</span> result;
}

<span class="cm">// Add two polynomials: O(max(m,n))</span>
<span class="kw">void</span> <span class="fn">addPoly</span>(<span class="kw">int</span> a[], <span class="kw">int</span> da, <span class="kw">int</span> b[], <span class="kw">int</span> db, <span class="kw">int</span> c[]) {
    <span class="kw">int</span> maxDeg = max(da, db);
    <span class="kw">for</span>(<span class="kw">int</span> i = <span class="num">0</span>; i <= maxDeg; i++) {
        <span class="kw">int</span> ca = (i <= da) ? a[i] : <span class="num">0</span>;
        <span class="kw">int</span> cb = (i <= db) ? b[i] : <span class="num">0</span>;
        c[i] = ca + cb;
    }
}

<span class="cm">// Multiply two polynomials: O(m*n)</span>
<span class="kw">void</span> <span class="fn">multiplyPoly</span>(<span class="kw">int</span> a[], <span class="kw">int</span> da, <span class="kw">int</span> b[], <span class="kw">int</span> db, <span class="kw">int</span> c[]) {
    <span class="kw">int</span> dc = da + db;
    <span class="kw">for</span>(<span class="kw">int</span> i = <span class="num">0</span>; i <= dc; i++) c[i] = <span class="num">0</span>;
    <span class="kw">for</span>(<span class="kw">int</span> i = <span class="num">0</span>; i <= da; i++)
        <span class="kw">for</span>(<span class="kw">int</span> j = <span class="num">0</span>; j <= db; j++)
            c[i+j] += a[i] * b[j];
}

<span class="kw">void</span> <span class="fn">display</span>(<span class="kw">int</span> p[], <span class="kw">int</span> deg) {
    <span class="kw">for</span>(<span class="kw">int</span> i = deg; i >= <span class="num">0</span>; i--) {
        <span class="kw">if</span>(p[i] != <span class="num">0</span>) {
            cout << p[i];
            <span class="kw">if</span>(i > <span class="num">0</span>) cout << <span class="str">"x^"</span> << i << <span class="str">"+"</span>;
        }
    }
    cout << endl;
}

<span class="kw">int</span> <span class="fn">main</span>() {
    <span class="cm">// A = 3x^2 + 2x + 1</span>
    <span class="kw">int</span> A[] = {<span class="num">1</span>, <span class="num">2</span>, <span class="num">3</span>}; <span class="kw">int</span> da = <span class="num">2</span>;
    <span class="cm">// B = x + 4</span>
    <span class="kw">int</span> B[] = {<span class="num">4</span>, <span class="num">1</span>}; <span class="kw">int</span> db = <span class="num">1</span>;
    <span class="kw">int</span> C[MAX] = {}, D[MAX] = {};

    <span class="fn">addPoly</span>(A, da, B, db, C);      <span class="fn">display</span>(C, <span class="num">2</span>);  <span class="cm">// 3x^2+3x+5</span>
    <span class="fn">multiplyPoly</span>(A, da, B, db, D); <span class="fn">display</span>(D, <span class="num">3</span>);  <span class="cm">// 3x^3+14x^2+9x+4</span>
    cout << <span class="fn">evaluate</span>(A, da, <span class="num">2.0</span>);                 <span class="cm">// A(2)=17</span>
}</pre>
  </div>
</section>

<!-- ======================== SPARSE MATRIX ======================== -->
<section id="sparse" class="section">
  <div class="section-badge badge-green">Unit I</div>
  <h2>Sparse Matrix</h2>
  <p>A matrix where most elements are zero. Storing all elements wastes memory — we store only non-zero elements.</p>
  <div class="card-grid">
    <div class="card">
      <h3>Problem</h3>
      <p>A 1000×1000 matrix with only 500 non-zero elements wastes ~4MB storing zeros. Sparse representation needs only ~6KB.</p>
    </div>
    <div class="card">
      <h3>Representation (Triplet)</h3>
      <p>Store each non-zero as triplet: (row, col, value). First row stores (rows, cols, total_non_zeros).</p>
    </div>
  </div>
  <div class="code-block">
    <div class="code-header"><div style="display:flex;align-items:center;gap:8px;"><div class="code-dots"><div class="code-dot dot-r"></div><div class="code-dot dot-y"></div><div class="code-dot dot-g"></div></div><span>sparse_matrix.cpp</span></div><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
    <pre><span class="kw">#include</span> <span class="str">&lt;iostream&gt;</span>
<span class="kw">using namespace</span> std;

<span class="kw">struct</span> <span class="tp">Triplet</span> { <span class="kw">int</span> row, col, val; };

<span class="kw">class</span> <span class="tp">SparseMatrix</span> {
    <span class="tp">Triplet</span> data[<span class="num">100</span>];
    <span class="kw">int</span> rows, cols, nnz; <span class="cm">// non-zero count</span>
<span class="kw">public</span>:
    <span class="fn">SparseMatrix</span>(<span class="kw">int</span> r, <span class="kw">int</span> c) : rows(r), cols(c), nnz(<span class="num">0</span>) {}

    <span class="kw">void</span> <span class="fn">insert</span>(<span class="kw">int</span> r, <span class="kw">int</span> c, <span class="kw">int</span> v) {
        <span class="kw">if</span>(v != <span class="num">0</span>) data[nnz++] = {r, c, v};
    }

    <span class="cm">// Transpose: swap row/col indices</span>
    <span class="tp">SparseMatrix</span> <span class="fn">transpose</span>() {
        <span class="tp">SparseMatrix</span> T(cols, rows);
        <span class="kw">for</span>(<span class="kw">int</span> i = <span class="num">0</span>; i < nnz; i++)
            T.<span class="fn">insert</span>(data[i].col, data[i].row, data[i].val);
        <span class="kw">return</span> T;
    }

    <span class="cm">// Add two sparse matrices</span>
    <span class="tp">SparseMatrix</span> <span class="fn">add</span>(<span class="tp">SparseMatrix</span>& B) {
        <span class="tp">SparseMatrix</span> C(rows, cols);
        <span class="kw">int</span> temp[<span class="num">10</span>][<span class="num">10</span>] = {};
        <span class="kw">for</span>(<span class="kw">int</span> i = <span class="num">0</span>; i < nnz; i++)
            temp[data[i].row][data[i].col] += data[i].val;
        <span class="kw">for</span>(<span class="kw">int</span> i = <span class="num">0</span>; i < B.nnz; i++)
            temp[B.data[i].row][B.data[i].col] += B.data[i].val;
        <span class="kw">for</span>(<span class="kw">int</span> i = <span class="num">0</span>; i < rows; i++)
            <span class="kw">for</span>(<span class="kw">int</span> j = <span class="num">0</span>; j < cols; j++)
                <span class="kw">if</span>(temp[i][j]) C.<span class="fn">insert</span>(i, j, temp[i][j]);
        <span class="kw">return</span> C;
    }

    <span class="kw">void</span> <span class="fn">display</span>() {
        cout << <span class="str">"Row\tCol\tVal\n"</span>;
        <span class="kw">for</span>(<span class="kw">int</span> i = <span class="num">0</span>; i < nnz; i++)
            cout << data[i].row << <span class="str">"\t"</span> << data[i].col << <span class="str">"\t"</span> << data[i].val << <span class="str">"\n"</span>;
    }
};</pre>
  </div>
</section>


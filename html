  </div>
  <div id="stack-tab">
    <div id="stack-pseudo" class="tab-content active">
      <div class="code-block">
        <div class="code-header"><div style="display:flex;align-items:center;gap:8px;"><div class="code-dots"><div class="code-dot dot-r"></div><div class="code-dot dot-y"></div><div class="code-dot dot-g"></div></div><span>Stack — Pseudocode</span></div><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="kw">INITIALIZE</span>: Stack S, top = -1, MAX_SIZE = n

<span class="kw">FUNCTION</span> <span class="fn">Push</span>(S, x):
  <span class="kw">IF</span> top == MAX_SIZE-1: ERROR "Stack Overflow"
  top = top + 1
  S[top] = x

<span class="kw">FUNCTION</span> <span class="fn">Pop</span>(S):
  <span class="kw">IF</span> top == -1: ERROR "Stack Underflow"
  x = S[top]
  top = top - 1
  <span class="kw">RETURN</span> x

<span class="kw">FUNCTION</span> <span class="fn">Peek</span>(S):
  <span class="kw">IF</span> top == -1: ERROR "Stack Empty"
  <span class="kw">RETURN</span> S[top]

<span class="kw">FUNCTION</span> <span class="fn">isEmpty</span>(S): <span class="kw">RETURN</span> top == -1
<span class="kw">FUNCTION</span> <span class="fn">isFull</span>(S): <span class="kw">RETURN</span> top == MAX_SIZE-1</pre>
      </div>
    </div>
    <div id="stack-cpp" class="tab-content">
      <div class="code-block">
        <div class="code-header"><div style="display:flex;align-items:center;gap:8px;"><div class="code-dots"><div class="code-dot dot-r"></div><div class="code-dot dot-y"></div><div class="code-dot dot-g"></div></div><span>stack.cpp</span></div><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="kw">#include</span> <span class="str">&lt;iostream&gt;</span>
<span class="kw">using namespace</span> std;

<span class="kw">class</span> <span class="tp">Stack</span> {
    <span class="kw">int</span>* arr;
    <span class="kw">int</span> top, maxSize;
<span class="kw">public</span>:
    <span class="fn">Stack</span>(<span class="kw">int</span> size) : maxSize(size), top(-<span class="num">1</span>) {
        arr = <span class="kw">new int</span>[size];
    }

    <span class="kw">bool</span> <span class="fn">isEmpty</span>() { <span class="kw">return</span> top == -<span class="num">1</span>; }
    <span class="kw">bool</span> <span class="fn">isFull</span>()  { <span class="kw">return</span> top == maxSize-<span class="num">1</span>; }

    <span class="cm">// O(1)</span>
    <span class="kw">void</span> <span class="fn">push</span>(<span class="kw">int</span> x) {
        <span class="kw">if</span>(<span class="fn">isFull</span>()) { cout << <span class="str">"Overflow!\n"</span>; <span class="kw">return</span>; }
        arr[++top] = x;
    }

    <span class="cm">// O(1)</span>
    <span class="kw">int</span> <span class="fn">pop</span>() {
        <span class="kw">if</span>(<span class="fn">isEmpty</span>()) { cout << <span class="str">"Underflow!\n"</span>; <span class="kw">return</span> -<span class="num">1</span>; }
        <span class="kw">return</span> arr[top--];
    }

    <span class="cm">// O(1)</span>
    <span class="kw">int</span> <span class="fn">peek</span>() {
        <span class="kw">if</span>(<span class="fn">isEmpty</span>()) { cout << <span class="str">"Empty!\n"</span>; <span class="kw">return</span> -<span class="num">1</span>; }
        <span class="kw">return</span> arr[top];
    }

    ~<span class="fn">Stack</span>() { <span class="kw">delete</span>[] arr; }
};

<span class="kw">int</span> <span class="fn">main</span>() {
    <span class="tp">Stack</span> s(<span class="num">5</span>);
    s.<span class="fn">push</span>(<span class="num">10</span>); s.<span class="fn">push</span>(<span class="num">20</span>); s.<span class="fn">push</span>(<span class="num">30</span>);
    cout << s.<span class="fn">peek</span>() << endl; <span class="cm">// 30</span>
    cout << s.<span class="fn">pop</span>()  << endl; <span class="cm">// 30</span>
    cout << s.<span class="fn">peek</span>() << endl; <span class="cm">// 20</span>
}</pre>
      </div>
    </div>
  </div>
</section>


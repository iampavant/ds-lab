<section id="queue-types" class="section">
  <div class="section-badge badge-yellow">Queue Variants</div>
  <h2>Queue Variants</h2>
  <p>Several specialized queue types solve specific problems — circular queues, deques, and priority queues.</p>

  <div class="card-grid">
    <div class="card" style="border-color:rgba(0,212,255,0.2)">
      <div class="card-icon">🔄</div>
      <h3 style="color:var(--accent)">Circular Queue</h3>
      <p>Rear wraps around to front. Solves the "false full" problem of linear queues. Used for buffering.</p>
    </div>
    <div class="card" style="border-color:rgba(124,58,237,0.2)">
      <div class="card-icon">↔️</div>
      <h3 style="color:#a78bfa">Deque (Double-ended)</h3>
      <p>Insert and delete from BOTH ends. More flexible than stack or queue.</p>
    </div>
    <div class="card" style="border-color:rgba(16,185,129,0.2)">
      <div class="card-icon">⭐</div>
      <h3 style="color:var(--accent3)">Priority Queue</h3>
      <p>Elements dequeued by priority, not arrival order. Basis for Dijkstra's, Prim's algorithms.</p>
    </div>
    <div class="card" style="border-color:rgba(245,158,11,0.2)">
      <div class="card-icon">📋</div>
      <h3 style="color:var(--accent4)">Job Scheduling</h3>
      <p>OS schedulers use queues. Round Robin uses circular queue. Priority scheduling uses priority queue.</p>
    </div>
  </div>

  <div class="code-block">
    <div class="code-header"><div style="display:flex;align-items:center;gap:8px;"><div class="code-dots"><div class="code-dot dot-r"></div><div class="code-dot dot-y"></div><div class="code-dot dot-g"></div></div><span>circular_queue.cpp</span></div><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
    <pre><span class="kw">class</span> <span class="tp">CircularQueue</span> {
    <span class="kw">int</span>* arr;
    <span class="kw">int</span> front, rear, size, maxSize;
<span class="kw">public</span>:
    <span class="fn">CircularQueue</span>(<span class="kw">int</span> n) : maxSize(n), front(<span class="num">0</span>), rear(<span class="num">0</span>), size(<span class="num">0</span>) {
        arr = <span class="kw">new int</span>[n];
    }

    <span class="kw">bool</span> <span class="fn">isEmpty</span>() { <span class="kw">return</span> size == <span class="num">0</span>; }
    <span class="kw">bool</span> <span class="fn">isFull</span>()  { <span class="kw">return</span> size == maxSize; }

    <span class="kw">void</span> <span class="fn">enqueue</span>(<span class="kw">int</span> x) {
        <span class="kw">if</span>(<span class="fn">isFull</span>()) { cout << <span class="str">"Full!\n"</span>; <span class="kw">return</span>; }
        arr[rear] = x;
        rear = (rear + <span class="num">1</span>) % maxSize; <span class="cm">// wrap around!</span>
        size++;
    }

    <span class="kw">int</span> <span class="fn">dequeue</span>() {
        <span class="kw">if</span>(<span class="fn">isEmpty</span>()) { cout << <span class="str">"Empty!\n"</span>; <span class="kw">return</span> -<span class="num">1</span>; }
        <span class="kw">int</span> x = arr[front];
        front = (front + <span class="num">1</span>) % maxSize; <span class="cm">// wrap around!</span>
        size--;
        <span class="kw">return</span> x;
    }
};</pre>
  </div>

  <div class="code-block">
    <div class="code-header"><div style="display:flex;align-items:center;gap:8px;"><div class="code-dots"><div class="code-dot dot-r"></div><div class="code-dot dot-y"></div><div class="code-dot dot-g"></div></div><span>priority_queue.cpp</span></div><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
    <pre><span class="kw">#include</span> <span class="str">&lt;queue&gt;</span>
<span class="kw">using namespace</span> std;

<span class="cm">// STL Priority Queue (max-heap by default)</span>
<span class="kw">int</span> <span class="fn">main</span>() {
    priority_queue&lt;<span class="kw">int</span>&gt; pq;
    pq.<span class="fn">push</span>(<span class="num">3</span>); pq.<span class="fn">push</span>(<span class="num">1</span>); pq.<span class="fn">push</span>(<span class="num">5</span>); pq.<span class="fn">push</span>(<span class="num">2</span>);

    <span class="kw">while</span>(!pq.<span class="fn">empty</span>()) {
        cout << pq.<span class="fn">top</span>() << <span class="str">" "</span>; <span class="cm">// prints: 5 3 2 1</span>
        pq.<span class="fn">pop</span>();
    }

    <span class="cm">// Min-heap (for Dijkstra's etc.)</span>
    priority_queue&lt;<span class="kw">int</span>, vector&lt;<span class="kw">int</span>&gt;, greater&lt;<span class="kw">int</span>&gt;&gt; minPQ;
    minPQ.<span class="fn">push</span>(<span class="num">3</span>); minPQ.<span class="fn">push</span>(<span class="num">1</span>); minPQ.<span class="fn">push</span>(<span class="num">5</span>);
    <span class="cm">// top() gives minimum: 1, 3, 5</span>
}

<span class="cm">// Job Scheduling with Priority Queue</span>
<span class="kw">struct</span> <span class="tp">Job</span> {
    <span class="kw">int</span> id, priority, burst;
    <span class="kw">bool operator</span>&lt;(<span class="kw">const</span> Job& other) <span class="kw">const</span> {
        <span class="kw">return</span> priority < other.priority; <span class="cm">// max-priority first</span>
    }
};

<span class="kw">void</span> <span class="fn">jobScheduling</span>(vector&lt;Job&gt;& jobs) {
    priority_queue&lt;Job&gt; pq;
    <span class="kw">for</span>(<span class="kw">auto</span>& j : jobs) pq.<span class="fn">push</span>(j);
    <span class="kw">while</span>(!pq.<span class="fn">empty</span>()) {
        <span class="tp">Job</span> j = pq.<span class="fn">top</span>(); pq.<span class="fn">pop</span>();
        cout << <span class="str">"Running Job "</span> << j.id << endl;
    }
}</pre>
  </div>

  <div class="highlight-box">
    <h4>📋 Deque (Double-Ended Queue)</h4>

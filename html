  <div class="code-block">
    <div class="code-header"><div style="display:flex;align-items:center;gap:8px;"><div class="code-dots"><div class="code-dot dot-r"></div><div class="code-dot dot-y"></div><div class="code-dot dot-g"></div></div><span>decimal_to_binary.cpp + infix_to_postfix.cpp</span></div><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
    <pre><span class="kw">#include</span> <span class="str">&lt;iostream&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;stack&gt;</span>
<span class="kw">#include</span> <span class="str">&lt;string&gt;</span>
<span class="kw">using namespace</span> std;

<span class="cm">// ========= Decimal to Binary =========</span>
<span class="kw">string</span> <span class="fn">decToBinary</span>(<span class="kw">int</span> n) {
    stack&lt;<span class="kw">int</span>&gt; s;
    <span class="kw">if</span>(n == <span class="num">0</span>) <span class="kw">return</span> <span class="str">"0"</span>;
    <span class="kw">while</span>(n > <span class="num">0</span>) {
        s.<span class="fn">push</span>(n % <span class="num">2</span>); <span class="cm">// push remainder</span>
        n /= <span class="num">2</span>;
    }
    <span class="kw">string</span> result = <span class="str">""</span>;
    <span class="kw">while</span>(!s.<span class="fn">empty</span>()) {
        result += to_string(s.<span class="fn">top</span>()); s.<span class="fn">pop</span>();
    }
    <span class="kw">return</span> result;
}

<span class="cm">// ========= Infix to Postfix =========</span>
<span class="kw">int</span> <span class="fn">precedence</span>(<span class="kw">char</span> op) {
    <span class="kw">if</span>(op == <span class="str">'^'</span>) <span class="kw">return</span> <span class="num">3</span>;
    <span class="kw">if</span>(op == <span class="str">'*'</span> || op == <span class="str">'/'</span>) <span class="kw">return</span> <span class="num">2</span>;
    <span class="kw">if</span>(op == <span class="str">'+'</span> || op == <span class="str">'-'</span>) <span class="kw">return</span> <span class="num">1</span>;
    <span class="kw">return</span> <span class="num">0</span>;
}

<span class="kw">string</span> <span class="fn">infixToPostfix</span>(<span class="kw">string</span> expr) {
    stack&lt;<span class="kw">char</span>&gt; s;
    <span class="kw">string</span> result = <span class="str">""</span>;
    <span class="kw">for</span>(<span class="kw">char</span> c : expr) {
        <span class="kw">if</span>(isalnum(c)) result += c; <span class="cm">// operand → output</span>
        <span class="kw">else if</span>(c == <span class="str">'('</span>) s.<span class="fn">push</span>(c);
        <span class="kw">else if</span>(c == <span class="str">')'</span>) {
            <span class="kw">while</span>(!s.<span class="fn">empty</span>() && s.<span class="fn">top</span>() != <span class="str">'('</span>)
                { result += s.<span class="fn">top</span>(); s.<span class="fn">pop</span>(); }
            s.<span class="fn">pop</span>(); <span class="cm">// remove '('</span>
        } <span class="kw">else</span> { <span class="cm">// operator</span>
            <span class="kw">while</span>(!s.<span class="fn">empty</span>() && <span class="fn">precedence</span>(s.<span class="fn">top</span>()) >= <span class="fn">precedence</span>(c))
                { result += s.<span class="fn">top</span>(); s.<span class="fn">pop</span>(); }
            s.<span class="fn">push</span>(c);
        }
    }
    <span class="kw">while</span>(!s.<span class="fn">empty</span>()) { result += s.<span class="fn">top</span>(); s.<span class="fn">pop</span>(); }
    <span class="kw">return</span> result;
}

<span class="kw">int</span> <span class="fn">main</span>() {
    cout << <span class="fn">decToBinary</span>(<span class="num">13</span>) << endl;             <span class="cm">// 1101</span>
    cout << <span class="fn">infixToPostfix</span>(<span class="str">"A+B*C"</span>) << endl;  <span class="cm">// ABC*+</span>
    cout << <span class="fn">infixToPostfix</span>(<span class="str">"(A+B)*C"</span>) << endl; <span class="cm">// AB+C*</span>
}</pre>
  </div>
</section>


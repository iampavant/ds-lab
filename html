  setMsg('array-msg', `✅ Inserted ${val} at index ${idx}. Array size: ${arrData.length}`);
}

function arrayDelete() {
  const idx = parseInt(document.getElementById('arr-idx').value);
  if(idx < 0 || idx >= arrData.length) { setMsg('array-msg', '❌ Invalid index'); return; }
  const val = arrData.splice(idx, 1)[0];
  renderArray();
  setMsg('array-msg', `🗑 Deleted ${val} from index ${idx}. Array size: ${arrData.length}`);
}

function arrayAccess() {
  const idx = parseInt(document.getElementById('arr-idx').value);
  if(idx < 0 || idx >= arrData.length) { setMsg('array-msg', '❌ Index out of bounds'); return; }
  renderArray(idx, 'highlight');
  setMsg('array-msg', `🔍 A[${idx}] = ${arrData[idx]} (O(1) direct access)`);
}

function arrayReset() {
  arrData = [12, 34, 56, 78, 90];
  renderArray();
  setMsg('array-msg', '↺ Array reset to initial state');
}

// ============================================================
// SEARCH VISUALIZER
// ============================================================
let searchArr = [2, 5, 8, 12, 16, 23, 38, 56, 72, 91];
let searchRunning = false;

function initSearchViz() {
  renderSearchArr();
}

function renderSearchArr(highlights = {}) {
  const viz = document.getElementById('search-viz');
  viz.innerHTML = searchArr.map((v, i) => {
    let cls = 'array-cell';
    if(highlights[i] === 'found') cls += ' sorted';
    else if(highlights[i] === 'current') cls += ' highlight';
    else if(highlights[i] === 'range') cls += ' comparing';
    else if(highlights[i] === 'mid') cls += ' pivot';
    return `<div class="${cls}">${v}<span class="idx">${i}</span></div>`;
  }).join('');
}

function delay(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

function getSearchSpeed() {
  const s = parseInt(document.getElementById('search-speed').value);
  return Math.max(100, 1100 - s * 100);
}

async function runLinearSearch() {
  if(searchRunning) return;
  searchRunning = true;
  const target = parseInt(document.getElementById('search-target').value);
  setMsg('search-msg', `🔍 Linear Search: looking for ${target}...`);

  for(let i = 0; i < searchArr.length; i++) {
    renderSearchArr({[i]: 'current'});
    await delay(getSearchSpeed());
    if(searchArr[i] === target) {
      renderSearchArr({[i]: 'found'});
      setMsg('search-msg', `✅ Found ${target} at index ${i} after ${i+1} comparison(s)!`);
      searchRunning = false; return;
    }
  }
  renderSearchArr();
  setMsg('search-msg', `❌ ${target} not found after ${searchArr.length} comparisons.`);
  searchRunning = false;
}

async function runBinarySearch() {
  if(searchRunning) return;
  searchRunning = true;
  const target = parseInt(document.getElementById('search-target').value);
  setMsg('search-msg', `⚡ Binary Search: looking for ${target}...`);
  let low = 0, high = searchArr.length - 1, steps = 0;

  while(low <= high) {
    steps++;
    const mid = Math.floor((low + high) / 2);
    const h = {};
    for(let i = low; i <= high; i++) h[i] = 'range';
    h[mid] = 'mid';
    renderSearchArr(h);
    setMsg('search-msg', `Step ${steps}: low=${low}, mid=${mid}(=${searchArr[mid]}), high=${high} | Target=${target}`);
    await delay(getSearchSpeed());

    if(searchArr[mid] === target) {
      renderSearchArr({[mid]: 'found'});
      setMsg('search-msg', `✅ Found ${target} at index ${mid} in ${steps} step(s)! O(log n)`);
      searchRunning = false; return;
    } else if(searchArr[mid] < target) low = mid + 1;
    else high = mid - 1;
  }
  renderSearchArr();
  setMsg('search-msg', `❌ ${target} not found after ${steps} step(s).`);
  searchRunning = false;
}

function resetSearch() {
  searchRunning = false;
  renderSearchArr();
  setMsg('search-msg', 'Enter a target value and choose a search algorithm.');
}

// ============================================================
// SORT VISUALIZER
// ============================================================
let sortArr = [];
let sortRunning = false;

function getSortSpeed() {
  const s = parseInt(document.getElementById('sort-speed').value);
  return Math.max(50, 1100 - s * 100);
}

function initSortViz() {
  sortArr = Array.from({length: 10}, () => Math.floor(Math.random() * 90) + 10);
  renderSortArr();
  setMsg('sort-msg', 'Click a sort algorithm to watch it work step by step!');
}

function renderSortArr(highlights = {}) {
  const viz = document.getElementById('sort-viz');
  const maxVal = Math.max(...sortArr);
  viz.innerHTML = sortArr.map((v, i) => {
    let cls = 'array-cell';
    if(highlights[i] === 'sorted') cls += ' sorted';
    else if(highlights[i] === 'comparing') cls += ' comparing';
    else if(highlights[i] === 'pivot') cls += ' pivot';
    else if(highlights[i] === 'highlight') cls += ' highlight';
    const h = Math.floor((v / maxVal) * 100);
    return `<div class="${cls}" style="height:${h}%;">${v}<span class="idx">${i}</span></div>`;
  }).join('');
}

async function runSort(type) {
  if(sortRunning) return;
  sortRunning = true;
  const arr = [...sortArr];

  if(type === 'bubble') await bubbleSortAnim(arr);
  else if(type === 'insertion') await insertionSortAnim(arr);
  else if(type === 'selection') await selectionSortAnim(arr);
  else if(type === 'quick') await quickSortAnim(arr, 0, arr.length-1);

  sortArr = arr;
  const allSorted = {};
  arr.forEach((_, i) => allSorted[i] = 'sorted');
  renderSortArr(allSorted);
  setMsg('sort-msg', `✅ ${type.charAt(0).toUpperCase()+type.slice(1)} Sort complete!`);
  sortRunning = false;
}

async function bubbleSortAnim(arr) {
  const n = arr.length;
  for(let i = 0; i < n-1; i++) {
    for(let j = 0; j < n-i-1; j++) {
      const h = {[j]:'comparing', [j+1]:'comparing'};
      for(let k = n-i; k < n; k++) h[k] = 'sorted';
      renderSortArr(h);
      setMsg('sort-msg', `Comparing arr[${j}]=${arr[j]} with arr[${j+1}]=${arr[j+1]}`);
      await delay(getSortSpeed());
      if(arr[j] > arr[j+1]) {
        [arr[j], arr[j+1]] = [arr[j+1], arr[j]];
        sortArr = [...arr];
      }
    }
  }
}

async function insertionSortAnim(arr) {
  const n = arr.length;
  for(let i = 1; i < n; i++) {
    let key = arr[i], j = i-1;
    renderSortArr({[i]:'highlight'});
    setMsg('sort-msg', `Inserting key=${key} into sorted portion [0..${i-1}]`);
    await delay(getSortSpeed());
    while(j >= 0 && arr[j] > key) {
      arr[j+1] = arr[j]; j--;
      sortArr = [...arr]; renderSortArr({[j+1]:'comparing'});
      await delay(getSortSpeed()/2);
    }
    arr[j+1] = key; sortArr = [...arr];
  }
}

async function selectionSortAnim(arr) {
  const n = arr.length;
  for(let i = 0; i < n-1; i++) {
    let minIdx = i;
    for(let j = i+1; j < n; j++) {
      renderSortArr({[minIdx]:'highlight', [j]:'comparing'});
      setMsg('sort-msg', `Finding min in [${i}..${n-1}]: current min at ${minIdx}=${arr[minIdx]}`);
      await delay(getSortSpeed()/2);
      if(arr[j] < arr[minIdx]) minIdx = j;
    }
    [arr[i], arr[minIdx]] = [arr[minIdx], arr[i]];
    sortArr = [...arr];
  }
}

async function quickSortAnim(arr, low, high) {
  if(low < high) {
    const pi = await partitionAnim(arr, low, high);
    await quickSortAnim(arr, low, pi-1);
    await quickSortAnim(arr, pi+1, high);
  }
}

async function partitionAnim(arr, low, high) {
  const pivot = arr[high];
  let i = low - 1;
  for(let j = low; j < high; j++) {
    renderSortArr({[high]:'pivot', [j]:'comparing'});
    setMsg('sort-msg', `Pivot=${pivot}, comparing arr[${j}]=${arr[j]}`);
    await delay(getSortSpeed());
    if(arr[j] <= pivot) {
      i++;
      [arr[i], arr[j]] = [arr[j], arr[i]];
      sortArr = [...arr];
    }
  }
  [arr[i+1], arr[high]] = [arr[high], arr[i+1]];
  sortArr = [...arr];
  return i+1;
}

function resetSort() { sortRunning = false; initSortViz(); }

// ============================================================
// STACK VISUALIZER
// ============================================================
let stack = [];
const MAX_STACK = 6;

function renderStackViz() {
  const viz = document.getElementById('stack-viz');
  viz.innerHTML = '<div class="stack-base"></div>';
  if(stack.length === 0) {
    viz.innerHTML += '<span class="stack-empty">Empty stack</span>';
  } else {
    stack.forEach((v, i) => {
      const isTop = i === stack.length - 1;
      const cell = document.createElement('div');
      cell.className = 'stack-cell' + (isTop ? ' top' : '');
      cell.textContent = v;
      if(isTop) cell.innerHTML += '<span class="top-label">← TOP</span>';
      viz.appendChild(cell);
    });
  }
  document.getElementById('stack-size').textContent = stack.length;
  document.getElementById('stack-top-val').textContent = stack.length ? stack[stack.length-1] : '-';
  document.getElementById('stack-empty-flag').textContent = stack.length === 0 ? 'Yes' : 'No';
}

function stackPush() {
  const val = parseInt(document.getElementById('stack-val').value);
  if(isNaN(val)) return;
  if(stack.length >= MAX_STACK) { setMsg('stack-msg', '❌ Stack Overflow! Max size reached.'); return; }
  stack.push(val);
  renderStackViz();
  setMsg('stack-msg', `✅ Pushed ${val} to top. Stack size: ${stack.length}`);
}

function stackPop() {
  if(stack.length === 0) { setMsg('stack-msg', '❌ Stack Underflow! Cannot pop from empty stack.'); return; }
  const val = stack.pop();
  renderStackViz();
  setMsg('stack-msg', `🔺 Popped ${val} from top. Stack size: ${stack.length}`);
}

function stackPeek() {
  if(stack.length === 0) { setMsg('stack-msg', '❌ Stack is empty. Nothing to peek.'); return; }
  setMsg('stack-msg', `👀 Top element is: ${stack[stack.length-1]} (stack unchanged)`);
  renderStackViz();
}

function resetStack() { stack = []; renderStackViz(); setMsg('stack-msg', '↺ Stack reset. Ready to use!'); }

// ============================================================
// QUEUE VISUALIZER
// ============================================================
let queue = [];

function renderQueueViz() {
  const viz = document.getElementById('queue-viz');
  const labels = document.getElementById('queue-labels');
  if(queue.length === 0) {
    viz.innerHTML = '<span style="color:var(--text2);font-size:13px;font-style:italic;">Empty queue</span>';
    labels.innerHTML = '';
  } else {
    viz.innerHTML = queue.map((v, i) => {
      let cls = 'queue-cell';
      if(i === 0) cls += ' front';
      if(i === queue.length-1 && queue.length > 1) cls += ' rear';
      return `<div class="${cls}">${v}</div>`;
    }).join('');
    labels.innerHTML = queue.map((_, i) => {
      let lbl = i === 0 ? 'FRONT' : (i === queue.length-1 ? 'REAR' : '');
      return `<div class="q-label" style="color:${i===0?'var(--accent3)':i===queue.length-1?'var(--accent4)':'transparent'}">${lbl}</div>`;
    }).join('');
  }
  document.getElementById('q-front').textContent = queue.length ? queue[0] : '-';
  document.getElementById('q-rear').textContent = queue.length ? queue[queue.length-1] : '-';
  document.getElementById('q-size').textContent = queue.length;
}

function queueEnqueue() {
  const val = parseInt(document.getElementById('queue-val').value);
  if(isNaN(val)) return;
  if(queue.length >= 8) { setMsg('queue-msg', '❌ Queue Full!'); return; }
  queue.push(val);
  renderQueueViz();
  setMsg('queue-msg', `✅ Enqueued ${val} at REAR. Size: ${queue.length}`);
}

function queueDequeue() {
  if(queue.length === 0) { setMsg('queue-msg', '❌ Queue Empty! Cannot dequeue.'); return; }
  const val = queue.shift();
  renderQueueViz();
  setMsg('queue-msg', `🔺 Dequeued ${val} from FRONT. Size: ${queue.length}`);
}

function resetQueue() { queue = []; renderQueueViz(); setMsg('queue-msg', 'Queue reset. Ready to use!'); }

// ============================================================
// DECIMAL TO BINARY
// ============================================================
function decToBin() {
  const n = parseInt(document.getElementById('dec-input').value);
  if(isNaN(n) || n < 0) return;
  document.getElementById('bin-dec').textContent = n;

  const steps = [];
  const stk = [];
  let tmp = n;
  if(tmp === 0) { stk.push(0); steps.push({q: 0, r: 0}); }
  while(tmp > 0) {
    const r = tmp % 2;
    stk.push(r);
    steps.push({q: Math.floor(tmp/2), r});
    tmp = Math.floor(tmp/2);
  }

  const binary = stk.reverse().join('');
  document.getElementById('bin-result').textContent = binary;

  const stepEl = document.getElementById('bin-steps');
  stepEl.innerHTML = steps.map((s, i) => `
    <div class="step-item done">Step ${i+1}: ${steps[i] === steps[0] ? n : steps[i-1]?.q ?? n} ÷ 2 = ${s.q}, remainder → Push(${s.r})</div>
  `).join('') + `<div class="step-item done">Pop all → ${binary}</div>`;
}

// ============================================================
// INFIX TO POSTFIX (simple visual)
// ============================================================
function infixToPostfix() {
  const expr = document.getElementById('expr-input').value.trim();
  document.getElementById('infix-display').textContent = expr;

  const prec = {'^':3,'*':2,'/':2,'+':1,'-':1,'(':0};
  const stk = []; let result = '';
  const steps = [];

  for(const c of expr) {
    if(/[a-zA-Z0-9]/.test(c)) {
      result += c;
      steps.push(`Read '${c}' → output: ${result}`);
    } else if(c === '(') {
      stk.push(c);
      steps.push(`Read '(' → push: [${[...stk].join(',')}]`);
    } else if(c === ')') {
      while(stk.length && stk[stk.length-1] !== '(') {
        result += stk.pop();
      }
      stk.pop();
      steps.push(`Read ')' → pop until '(': output: ${result}`);
    } else {
      while(stk.length && prec[stk[stk.length-1]] >= prec[c]) {
        result += stk.pop();
      }
      stk.push(c);
      steps.push(`Read '${c}' → push: [${[...stk].join(',')}], output: ${result}`);
    }
  }
  while(stk.length) {
    result += stk.pop();
  }
  steps.push(`End → pop remaining: ${result}`);

  document.getElementById('postfix-display').textContent = result;
  document.getElementById('expr-steps').innerHTML = steps.map(s =>
    `<div class="step-item done">${s}</div>`).join('');
}


    <div id="queue-cpp" class="tab-content">
      <div class="code-block">
        <div class="code-header"><div style="display:flex;align-items:center;gap:8px;"><div class="code-dots"><div class="code-dot dot-r"></div><div class="code-dot dot-y"></div><div class="code-dot dot-g"></div></div><span>queue.cpp</span></div><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
        <pre><span class="kw">#include</span> <span class="str">&lt;iostream&gt;</span>
<span class="kw">using namespace</span> std;

<span class="kw">class</span> <span class="tp">Queue</span> {
    <span class="kw">int</span>* arr;
    <span class="kw">int</span> front, rear, maxSize;
<span class="kw">public</span>:
    <span class="fn">Queue</span>(<span class="kw">int</span> size) : maxSize(size), front(-<span class="num">1</span>), rear(-<span class="num">1</span>) {
        arr = <span class="kw">new int</span>[size];
    }

    <span class="kw">bool</span> <span class="fn">isEmpty</span>() { <span class="kw">return</span> front == -<span class="num">1</span>; }
    <span class="kw">bool</span> <span class="fn">isFull</span>()  { <span class="kw">return</span> rear == maxSize - <span class="num">1</span>; }

    <span class="cm">// O(1)</span>
    <span class="kw">void</span> <span class="fn">enqueue</span>(<span class="kw">int</span> x) {
        <span class="kw">if</span>(<span class="fn">isFull</span>()) { cout << <span class="str">"Queue Full!\n"</span>; <span class="kw">return</span>; }
        <span class="kw">if</span>(front == -<span class="num">1</span>) front = <span class="num">0</span>;
        arr[++rear] = x;
    }

    <span class="cm">// O(1)</span>
    <span class="kw">int</span> <span class="fn">dequeue</span>() {
        <span class="kw">if</span>(<span class="fn">isEmpty</span>()) { cout << <span class="str">"Queue Empty!\n"</span>; <span class="kw">return</span> -<span class="num">1</span>; }
        <span class="kw">int</span> x = arr[front];
        <span class="kw">if</span>(front == rear) front = rear = -<span class="num">1</span>;
        <span class="kw">else</span> front++;
        <span class="kw">return</span> x;
    }

    <span class="kw">int</span> <span class="fn">frontVal</span>() { <span class="kw">return</span> <span class="fn">isEmpty</span>() ? -<span class="num">1</span> : arr[front]; }

    ~<span class="fn">Queue</span>() { <span class="kw">delete</span>[] arr; }
};

<span class="kw">int</span> <span class="fn">main</span>() {
    <span class="tp">Queue</span> q(<span class="num">5</span>);
    q.<span class="fn">enqueue</span>(<span class="num">10</span>); q.<span class="fn">enqueue</span>(<span class="num">20</span>); q.<span class="fn">enqueue</span>(<span class="num">30</span>);
    cout << q.<span class="fn">dequeue</span>() << endl;    <span class="cm">// 10 (FIFO)</span>
    cout << q.<span class="fn">frontVal</span>() << endl;  <span class="cm">// 20</span>
}</pre>

  rear = rear + 1
  Q[rear] = x

<span class="kw">FUNCTION</span> <span class="fn">Dequeue</span>(Q):
  <span class="kw">IF</span> front == -1: ERROR "Queue Underflow"
  x = Q[front]
  <span class="kw">IF</span> front == rear: front = rear = -1  <span class="cm">// last element</span>
  <span class="kw">ELSE</span>: front = front + 1
  <span class="kw">RETURN</span> x

<span class="kw">FUNCTION</span> <span class="fn">Front</span>(Q): <span class="kw">RETURN</span> Q[front]
<span class="kw">FUNCTION</span> <span class="fn">isEmpty</span>(Q): <span class="kw">RETURN</span> front == -1</pre>

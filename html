        <pre><span class="kw">INITIALIZE</span>: Queue Q[MAX], front = -1, rear = -1

<span class="kw">FUNCTION</span> <span class="fn">Enqueue</span>(Q, x):
  <span class="kw">IF</span> rear == MAX-1: ERROR "Queue Overflow"

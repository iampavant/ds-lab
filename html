        <div class="progress-bar" style="flex:1;"><div class="progress-fill" style="width:15%;background:var(--accent3);"></div></div>
        <span style="font-size:12px; color:var(--text2);">Logarithmic — Excellent</span>
      </div>
      <div style="display:flex; align-items:center; gap:12px;">
        <span style="font-family:'JetBrains Mono',monospace; color:var(--accent); width:110px; font-size:13px;">O(n)</span>
